{
    "_version": "1.58.0",
    "sap.app": {
        "id": "product.dashboard",
        "type": "application",
        "title": "Product Dashboard",
        "applicationVersion": {
            "version": "1.0.0"
        }
    },
    "sap.ui5": {
        "rootView": {
            "viewName": "product.dashboard.view.App",
            "type": "XML",
            "async": true,
            "id": "app"
        },
        "dependencies": {
            "minUI5Version": "1.108.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {}
            }
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "viewPath": "product.dashboard.view",
                "controlId": "myNavContainer",
                "controlAggregation": "pages",
                "async": true
            },
            "routes": [
                {
                    "name": "products",
                    "pattern": "",
                    "target": "products"
                },
                {
                    "name": "detail",
                    "pattern": "detail/{productId}",
                    "target": "detail"
                }
            ],
            "targets": {
                "products": {
                    "viewName": "Products",
                    "viewId": "products"
                },
                "detail": {
                    "viewName": "Detail",
                    "viewId": "detail"
                }
            }
        }
    }
}